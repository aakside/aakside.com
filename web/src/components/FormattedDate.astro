---
interface Props {
  date: Date;
}

const { date } = Astro.props;
const fallbackDateTime = date.toLocaleDateString("en-us", {
  year: "numeric",
  month: "short",
  day: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  hour12: false,
  timeZoneName: "short",
});
---

<time data-localized-date datetime={date.toISOString()}>
  {fallbackDateTime}
</time>
