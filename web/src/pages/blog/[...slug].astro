---
import { getCollection, render } from "astro:content";
import BlogPost from "../../layouts/BlogPost.astro";
import {
  getGitHubRepoPathForEntry,
  latestCommitDiffUrlForEntry,
  withGitContentDates,
} from "../../utils/content-meta";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = withGitContentDates<"blog">(Astro.props);
const { Content, headings } = await render(post);
const sourcePath = getGitHubRepoPathForEntry(post);
const latestCommitDiffUrl = latestCommitDiffUrlForEntry(post);
---

<BlogPost
  {...post.data}
  headings={headings}
  sourcePath={sourcePath}
  latestCommitDiffUrl={latestCommitDiffUrl}
>
  <Content />
</BlogPost>
