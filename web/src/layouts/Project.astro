---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import FormattedDate from "../components/FormattedDate.astro";

type Props = CollectionEntry<"projects">["data"];

const { title, description, favicon, pubDate, updatedDate, heroAlt, heroImage } = Astro.props;
const { minimalLayout = false } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      favicon={favicon}
      heroAlt={heroAlt}
      image={heroImage}
    />
    <meta name="theme-color" content="steelblue" />
    <script src="../scripts/theme-color.ts"></script>
  </head>

  <body>
    {
      !minimalLayout && (
        <>
          <div class="hero-image">
            {heroImage && <Image alt={heroAlt!} height={510} src={heroImage} width={1020} />}
          </div>
          <div class="title">
            <h1>{title}</h1>
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
                <div class="last-updated-on">
                  Last updated on <FormattedDate date={updatedDate} />
                </div>
              )}
            </div>
            <hr />
          </div>
        </>
      )
    }
    <slot />
  </body>
</html>
